{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Drift Society Help Center",
  "colors": {
    "primary": "#4177ff",
    "light": "#4177ff",
    "dark": "#4177ff"
  },
  "favicon": "logo/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Help Center",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "overview/introduction",
              "overview/changelog",
              "overview/faq",
              "overview/products"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/keybinds",
              "guides/commands",
              "guides/joining",
              "guides/playstation",
              "guides/drift"
            ]
